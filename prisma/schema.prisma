// Community Management System - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("member") // admin | leader | project_manager | finance | volunteer | member
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member      Member?
  approvals   ResourceAllocation[] @relation("Approver")
  auditLogs   AuditLog[]
  announcements Announcement[]
}

model Member {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  gender       String?  // male | female | other
  age          Int?
  phone        String?
  address      String?
  category     String   @default("general") // youth | elder | family | leader | volunteer
  skills       String?  // comma-separated
  needs        String?  // comma-separated
  householdSize Int     @default(1)
  status       String   @default("active") // active | inactive
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contributions Contribution[]
  feedback      Feedback[]
}

model Resource {
  id           String   @id @default(cuid())
  name         String
  category     String   // fund | equipment | material | food | medicine | human
  unit         String   @default("unit")
  quantity     Float    @default(0)
  reserved     Float    @default(0)
  threshold    Float    @default(0) // shortage alert threshold
  location     String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  allocations  ResourceAllocation[]
}

model ResourceAllocation {
  id           String   @id @default(cuid())
  resourceId   String
  resource     Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  quantity     Float
  reason       String
  status       String   @default("pending") // pending | approved | rejected | distributed
  requesterId  String?
  approverId   String?
  approver     User?    @relation("Approver", fields: [approverId], references: [id])
  requestedAt  DateTime @default(now())
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String   @default("infrastructure") // infrastructure | health | education | environment | social | economic
  goal         String?
  budget       Float    @default(0)
  spent        Float    @default(0)
  startDate    DateTime
  endDate      DateTime?
  progress     Float    @default(0) // 0-100
  status       String   @default("planning") // planning | active | completed | delayed | on_hold
  managerId    String?
  managerName  String?
  location     String?
  beneficiaries Int    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  milestones   Milestone[]
  feedback     Feedback[]
  allocations  ResourceAllocation[]
  transactions Transaction[]
}

model Milestone {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  dueDate      DateTime
  completed    Boolean  @default(false)
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Transaction {
  id           String   @id @default(cuid())
  type         String   // income | donation | grant | expense
  category     String   // e.g. membership, fundraising, government_grant, salary, supplies
  amount       Float
  description  String?
  source       String?  // funding source / payee
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  date         DateTime @default(now())
  status       String   @default("completed") // pending | approved | completed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Contribution {
  id           String   @id @default(cuid())
  memberId     String
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type         String   // time | money | material | skill
  description  String
  value        Float    @default(0)
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
}

model Feedback {
  id           String   @id @default(cuid())
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  memberId     String?
  member       Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  rating       Int      @default(5) // 1-5
  category     String   @default("general") // general | project | resource | leadership
  content      String
  sentiment    String   @default("neutral") // positive | neutral | negative
  status       String   @default("open") // open | addressed
  createdAt    DateTime @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String   // create | update | delete | approve | login
  entity       String   // member | resource | project | transaction | allocation
  entityId     String?
  details      String?
  createdAt    DateTime @default(now())
}

model Announcement {
  id           String   @id @default(cuid())
  title        String
  content      String
  category     String   @default("general") // general | urgent | event | meeting
  authorId     String?
  author       User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  pinned       Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Alert {
  id           String   @id @default(cuid())
  type         String   // shortage | delay | budget | risk | feedback
  severity     String   @default("warning") // info | warning | critical
  title        String
  message      String
  relatedId    String?
  relatedType  String?
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Category {
  id           String   @id @default(cuid())
  type         String   // member | resource | project | announcement | feedback | transaction_type
  value        String   // lowercase identifier stored on records (e.g. "leader")
  label        String   // display name (e.g. "Leader")
  color        String   @default("gray") // gray|emerald|amber|red|cyan|violet|rose|teal
  icon         String?
  active       Boolean  @default(true)
  isSystem     Boolean  @default(false) // system categories cannot be deleted (only hidden)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([type, value])
}
